{{ 'section-image-grid-with-text.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  #CustomWorkout-{{ section.id }} .custom-workout__section-heading {
    font-size: {{ section.settings.heading_size_mobile }}px;
  }
  #CustomWorkout-{{ section.id }} .custom-workout__large-heading {
    font-size: {{ section.settings.large_heading_size_mobile }}px;
  }
  #CustomWorkout-{{ section.id }} .custom-workout__subheading {
    font-size: {{ section.settings.subheading_size_mobile }}px;
  }
  #CustomWorkout-{{ section.id }} .custom-workout__content {
    font-size: {{ section.settings.content_size_mobile }}px;
  }

  @media screen and (min-width: 750px) {
    #CustomWorkout-{{ section.id }} .custom-workout__section-heading {
      font-size: {{ section.settings.heading_size }}px;
    }
    #CustomWorkout-{{ section.id }} .custom-workout__large-heading {
      font-size: {{ section.settings.large_heading_size }}px;
    }
    #CustomWorkout-{{ section.id }} .custom-workout__subheading {
      font-size: {{ section.settings.subheading_size }}px;
    }
    #CustomWorkout-{{ section.id }} .custom-workout__content {
      font-size: {{ section.settings.content_size }}px;
    }
  }
{%- endstyle -%}

<div class="section-{{ section.id }}-padding color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width" id="CustomWorkout-{{ section.id }}">
    
    {%- if section.settings.section_heading != blank -%}
      <h2 class="custom-workout__section-heading">{{ section.settings.section_heading | escape }}</h2>
    {%- endif -%}

    {%- assign layout_class = '' -%}
    {%- if section.settings.layout == 'text_first' -%}
      {%- assign layout_class = ' custom-workout-section--reverse' -%}
    {%- endif -%}

    <div class="custom-workout-section{{ layout_class }}">
      <div class="custom-workout-section__left">
        <div class="custom-workout__left-images">
          {%- if section.blocks.size > 0 -%}
            <div class="custom-workout__gallery">
              {%- for block in section.blocks -%}
                <div class="custom-workout__gallery-item desktop-width-{{ block.settings.desktop_width }} mobile-width-{{ block.settings.mobile_width }}" {{ block.shopify_attributes }}>
                  {%- if block.settings.image != blank -%}
                    <div class="custom-workout__image-wrapper {% if block.settings.mobile_image != blank %}desktop-only{% endif %}">
                      {{ block.settings.image | image_url: width: 800 | image_tag: loading: 'lazy', sizes: '(min-width: 750px) 18vw, 100vw', widths: '375, 550, 800' }}
                    </div>
                  {%- endif -%}
                  {%- if block.settings.mobile_image != blank -%}
                    <div class="custom-workout__image-wrapper mobile-only">
                      {{ block.settings.mobile_image | image_url: width: 750 | image_tag: loading: 'lazy', sizes: '100vw', widths: '375, 550, 750' }}
                    </div>
                  {%- endif -%}
                  {%- if block.settings.image == blank and block.settings.mobile_image == blank -%}
                    {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                  {%- endif -%}
                </div>
              {%- endfor -%}
            </div>
          {%- endif -%}

          {%- if section.settings.image != blank or section.settings.image_mobile != blank -%}
            <div class="custom-workout__top-image">
              {%- if section.settings.image != blank -%}
                <div class="custom-workout__image-wrapper {% if section.settings.image_mobile != blank %}desktop-only{% endif %}">
                  {{ section.settings.image | image_url: width: 1500 | image_tag: loading: 'lazy', sizes: '(min-width: 750px) 55vw, 100vw', widths: '375, 550, 750, 1100, 1500' }}
                </div>
              {%- endif -%}
              {%- if section.settings.image_mobile != blank -%}
                <div class="custom-workout__image-wrapper mobile-only">
                  {{ section.settings.image_mobile | image_url: width: 750 | image_tag: loading: 'lazy', sizes: '100vw', widths: '375, 550, 750' }}
                </div>
              {%- endif -%}
            </div>
          {%- endif -%}
        </div>
      </div>
      
      <div class="custom-workout-section__right">
        <div class="custom-workout-section__right-inner color-{{ section.settings.right_color_scheme }} gradient">
          {%- if section.settings.large_heading != blank -%}
            <h2 class="custom-workout__large-heading">{{ section.settings.large_heading | escape }}</h2>
          {%- endif -%}
          {%- if section.settings.subheading != blank -%}
            <h3 class="custom-workout__subheading">{{ section.settings.subheading | escape }}</h3>
          {%- endif -%}
          {%- if section.settings.content != blank -%}
            <div class="custom-workout__content rte">
              {{ section.settings.content }}
            </div>
          {%- endif -%}
        </div>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Image Grid with Text",
  "class": "section",
  "settings": [
    {
      "type": "select",
      "id": "layout",
      "options": [
        {
          "value": "image_first",
          "label": "Image first"
        },
        {
          "value": "text_first",
          "label": "Text first"
        }
      ],
      "default": "image_first",
      "label": "Section Layout"
    },
    {
      "type": "header",
      "content": "Color"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Section Color Scheme",
      "default": "scheme-1"
    },
    {
      "type": "inline_richtext",
      "id": "section_heading",
      "label": "Heading",
      "default": "Customizable Workout Programs"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 12,
      "max": 60,
      "step": 1,
      "unit": "px",
      "label": "Desktop Font Size",
      "default": 32
    },
    {
      "type": "range",
      "id": "heading_size_mobile",
      "min": 12,
      "max": 48,
      "step": 1,
      "unit": "px",
      "label": "Mobile Font Size",
      "default": 24
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image",
      "info": "Apply on Desktop"
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Image",
      "info": "Apply on Mobile"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "color_scheme",
      "id": "right_color_scheme",
      "label": "Right Box Color Scheme",
      "default": "scheme-1"
    },
    {
      "type": "inline_richtext",
      "id": "large_heading",
      "label": "Large Heading",
      "default": "18"
    },
    {
      "type": "range",
      "id": "large_heading_size",
      "min": 24,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Large Heading Desktop Size",
      "default": 100
    },
    {
      "type": "range",
      "id": "large_heading_size_mobile",
      "min": 24,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Large Heading Mobile Size",
      "default": 60
    },
    {
      "type": "inline_richtext",
      "id": "subheading",
      "label": "Subheading",
      "default": "Customizable Preset Workouts"
    },
    {
      "type": "range",
      "id": "subheading_size",
      "min": 12,
      "max": 60,
      "step": 1,
      "unit": "px",
      "label": "Subheading Desktop Size",
      "default": 24
    },
    {
      "type": "range",
      "id": "subheading_size_mobile",
      "min": 12,
      "max": 48,
      "step": 1,
      "unit": "px",
      "label": "Subheading Mobile Size",
      "default": 20
    },
    {
      "type": "richtext",
      "id": "content",
      "label": "Content",
      "default": "<p>Start with 18 preset workout programs and fully customize each one to match your fitness goals, experience level, and training style.</p>"
    },
    {
      "type": "range",
      "id": "content_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Content Desktop Size",
      "default": 16
    },
    {
      "type": "range",
      "id": "content_size_mobile",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Content Mobile Size",
      "default": 14
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Top",
      "default": 36,
      "info": "Apply on Desktop"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 36,
      "info": "Apply on Desktop"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Top",
      "default": 36,
      "info": "Apply on Mobile"
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 36,
      "info": "Apply on Mobile"
    }
  ],
  "blocks": [
    {
      "type": "gallery_image",
      "name": "Gallery Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image",
          "info": "Apply on Desktop"
        },
        {
          "type": "image_picker",
          "id": "mobile_image",
          "label": "Image",
          "info": "Apply on Mobile"
        },
        {
          "type": "select",
          "id": "desktop_width",
          "label": "Desktop Column Width",
          "options": [
            { "value": "50", "label": "50%" },
            { "value": "33", "label": "33%" },
            { "value": "25", "label": "25%" },
            { "value": "100", "label": "100%" }
          ],
          "default": "33"
        },
        {
          "type": "select",
          "id": "mobile_width",
          "label": "Mobile Column Width",
          "options": [
            { "value": "50", "label": "50%" },
            { "value": "33", "label": "33%" },
            { "value": "100", "label": "100%" }
          ],
          "default": "50"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Image Grid with Text",
      "blocks": [
        {
          "type": "gallery_image"
        },
        {
          "type": "gallery_image"
        },
        {
          "type": "gallery_image"
        }
      ]
    }
  ]
}
{% endschema %}